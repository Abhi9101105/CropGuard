# CropGuard AI Backend — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to version control

# ─── MongoDB ───────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=cropguard_db

# ─── Authentication ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_strong_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Application ───────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOAD_DIR=./uploads

# ─── AI APIs ───────────────────────────────────────────
# Gemini Vision — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq LLaMA Fallback — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Weather ───────────────────────────────────────────
# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── Location Defaults ─────────────────────────────────
DEFAULT_LAT=17.6868
DEFAULT_LON=83.2185
DEFAULT_CITY=Visakhapatnam

# ─── Optional: Kaggle (for model training only) ────────
KAGGLE_USERNAME=
KAGGLE_KEY=
